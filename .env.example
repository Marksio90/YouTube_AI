# =============================================================================
# AI Media OS — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# POSTGRES_HOST/PORT/DB/USER/PASSWORD are used by Docker Compose only (postgres
# container config + healthcheck). The app reads DATABASE_URL directly.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_media_os
POSTGRES_USER=media_os
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+asyncpg://media_os:change-me-db-password@postgres:5432/ai_media_os

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_HOST/PORT are used by Docker Compose only. The app reads REDIS_URL and
# CELERY_* directly. REDIS_PASSWORD is used by both Docker Compose and the URLs.
# RedBeat (beat scheduler) uses REDIS_URL — no separate REDBEAT_REDIS_URL needed.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@redis:6379/2

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Which provider to use: openai | local | mock
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
LLM_DEFAULT_MODEL=gpt-4o-mini
# Local LLM settings (only needed when LLM_PROVIDER=local)
LLM_LOCAL_BASE_URL=http://localhost:11434/v1
LLM_LOCAL_MODEL=mistral

# ── TTS (Text-to-Speech) ──────────────────────────────────────────────────────
# Which TTS engine to use: openai | elevenlabs
TTS_PROVIDER_DEFAULT=openai
ELEVENLABS_API_KEY=

# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/youtube/callback

# ── Storage (S3-compatible) ───────────────────────────────────────────────────
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_MEDIA=ai-media-os-media
S3_BUCKET_EXPORTS=ai-media-os-exports
S3_REGION=us-east-1

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Celery / Flower ───────────────────────────────────────────────────────────
# FLOWER_BASIC_AUTH is passed directly to the Flower container (not read by
# pydantic-settings); format: user:password
FLOWER_BASIC_AUTH=admin:change-me-flower-password

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

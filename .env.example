# =============================================================================
# AI Media OS — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_media_os
POSTGRES_USER=media_os
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+asyncpg://media_os:change-me-db-password@postgres:5432/ai_media_os

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@redis:6379/2

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Which provider to use: openai | anthropic | local | mock
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_DEFAULT_MODEL=gpt-4o-mini
# Local LLM settings (only needed when LLM_PROVIDER=local)
LLM_LOCAL_BASE_URL=http://localhost:11434/v1
LLM_LOCAL_MODEL=mistral

# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/youtube/callback

# ── Storage (S3-compatible) ───────────────────────────────────────────────────
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_MEDIA=ai-media-os-media
S3_BUCKET_EXPORTS=ai-media-os-exports
S3_REGION=us-east-1

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_RETENTION_DAYS=730

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Auth (NextAuth / JWT) ─────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Celery / Flower ───────────────────────────────────────────────────────────
FLOWER_BASIC_AUTH=admin:change-me-flower-password
# RedBeat uses REDIS_URL for beat schedule persistence
REDBEAT_REDIS_URL=redis://:change-me-redis-password@redis:6379/3

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
